#!/usr/bin/env bash
# This script just makes sure the deps are available and does not update
# them. For that use `sudo pacman -Syu` or `brew upgrade`.

declare -A -r PACKAGES=(
    # ['k3d']='rancher-k3d-bin k3d' # requires AUR
    ['curl']=''
    ['git']=''
    ['gopls']=''
    ['glow']=''
    ['hf']='huggingface-cli python-huggingface-hub'
    ['kubectl']=''
    ['make']=''
    ['nvim']='neovim'
    ['vim']='gvim vim'
    ['pip']=''
    ['pipx']=''
    ['python']=''
    ['rg']='ripgrep'
    ['fd']='fd'
    ['shellcheck']=''
    ['tmux']=''
    ['wget']=''
    ['yq']='go-yq yq'
    ['docker']=''
    ['docker-compose']=''
    ['cwebp']='libwebp-utils'
    ['clojure']=''
)

OS="$(uname)"
to_install=""

for key in "${!PACKAGES[@]}"; do
    if command -v "$key" >/dev/null 2>&1; then
        echo "✔  $key is already installed. Skipping..."
        continue
    fi

    val="${PACKAGES[$key]}"
    pkg_to_add=""

    if [[ -z "$val" ]]; then
        pkg_to_add="$key"
    else
        read -r -a parts <<< "$val"
        if [[ ${#parts[@]} -eq 1 ]]; then
            pkg_to_add="${parts[0]}"
        else
            if [[ "$OS" == "Linux" ]]; then
                pkg_to_add="${parts[0]}"
            else
                pkg_to_add="${parts[1]}"
            fi
        fi
    fi

    echo "+ $key not found. Adding '$pkg_to_add' to install list."
    to_install="$to_install $pkg_to_add"
done

# Trim whitespace
to_install=$(echo "$to_install" | xargs)

echo "--------------------------"

if [[ -z "$to_install" ]]; then
    echo "All dependencies are already satisfied."
else
    echo "Final install list: $to_install"

    if [[ "$OS" == "Linux" ]]; then
        sudo pacman -S --needed $to_install
    else
        brew install $to_install
    fi
fi

echo "--------------------------"

pkg_base="$HOME/.vim/pack/base"
local_bin="$HOME/.local/bin"


plugin() {
    local slug="$1"
    local sub_dir="${2:-start}"
    local repo_name="${slug#*/}"
    local target_dir="$pkg_base/$sub_dir/$repo_name"

    if [[ ! -d "$target_dir" ]]; then
        echo "Cloning $slug into $sub_dir..."
        git clone "https://github.com/$slug.git" "$target_dir" --depth=1
    else
        echo "$repo_name already exists in $sub_dir. Skipping."
    fi
}

mkdir -p $pkg_base/start $pkg_base/opt

echo 'Ensuring vim plugins and selecta are available'

plugin "tpope/vim-fireplace" "opt"
plugin "tpope/vim-fugitive"
plugin "tpope/vim-dadbod"
plugin "junegunn/vim-easy-align"

if [[ ! -f $local_bin/selecta ]]; then
  curl -L -o "$local_bin/selecta" \
    https://github.com/garybernhardt/selecta/raw/refs/heads/master/selecta
  chmod +x "$local_bin/selecta"
fi
