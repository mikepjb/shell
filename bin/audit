#!/usr/bin/env bash

COL_WIDTH=45  # Total width for each column
TOP_N=15      # How many rows to show per section

get_line_counts() {
    git ls-files -z | xargs -0 wc -l 2>/dev/null | awk '
        $2 != "total" && $2 != "" {
            n = split($2, a, ".");
            ext = (n > 1) ? a[n] : "no_ext";
            sum[ext] += $1
        }
        END { for (e in sum) printf "%-8d %s\n", sum[e], e }' | sort -rn | head -n "$TOP_N"
}

get_pace() {
    git log --format='%ad' --date=format:'%Y-%m' | sort | uniq -c | sort -k2 -r | head -n "$TOP_N" | awk '{ printf "%-8s %s\n", $1, $2 }'
}

condense_path() {
    awk -v max=30 '{
        count=$1; path=$2;
        if (length(path) > max) {
            # Keep the last X characters and prepend dots
            path = "..." substr(path, length(path) - (max - 3))
        }
        printf "%-8s %s\n", count, path
    }'
}

get_file_changes() {
    git log --format=format: --name-only --since="1 year ago" | grep -v '^$' \
        | sort | uniq -c | sort -nr | head -n "$TOP_N" \
        | condense_path
}

get_hotspots() {
    git log -i -E --grep="revert|hotfix|emergency|rollback|fix|bug|broken" \
        --name-only --format='' | grep -v '^$' \
        | sort | uniq -c | sort -nr | head -n "$TOP_N" \
        | condense_path
}

get_authors() {
    local since=$1
    git shortlog -sn --no-merges ${since:+--since="$since"} | head -n "$TOP_N" \
        | awk '{ count=$1; $1=""; printf "%-8s %s\n", count, $0 }'
}

print_section() {
    local title1=$1
    local title2=$2
    local cmd1=$3
    local cmd2=$4

    # Print Headers
    printf "%-${COL_WIDTH}s | %s\n" "$title1" "$title2"
    printf "%-${COL_WIDTH}s | %s\n" "-----------------------" "-----------------------"

    # Paste the results of the two functions side-by-side
    # The 'pr' command handles the padding and the vertical separator
    paste <(eval "$cmd1") <(eval "$cmd2") | awk -F'\t' -v w="$COL_WIDTH" '{ printf "%-"w"s | %s\n", $1, $2 }'
    echo -e "\n"
}

echo "Auditing: $(basename "$PWD")"
echo "Project Path: $(pwd)"
echo "Number of TODOs: $(rg TODO | wc -l)"
echo -e "--------------------------------------------------------------------------------\n"

print_section "LINE COUNTS" "PACE (COMMITS/MO)" "get_line_counts" "get_pace"
print_section "CHANGES (1YR)" "HOTSPOTS (BUG FIXES)" "get_file_changes" "get_hotspots"
print_section "AUTHORS (ALL TIME)" "AUTHORS (6 MONTHS)" "get_authors" "get_authors '6 months ago'"

echo "--------------------------------------------------------------------------------"
