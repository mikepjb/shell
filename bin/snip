case "$1" in
    html) echo "$snip_html";;
    css) echo "$snip_css";;
    task) echo "$snip_task";;
    deps) echo "$snip_deps";;
    cljs) echo "$snip_cljs";;
    htmx) echo "$snip_htmx";;
    core) echo "$snip_core";;
    user) echo "$snip_user";;
    mit) echo "$snip_mit";;
    *) echo "No snip for '$1' was found";;
esac
