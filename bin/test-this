#!/usr/bin/env bash
#
# test-this is a script that will either run a single test file or the entire
# test suite of your project.
#
# This depends on whether test-this is given an argument, which will be assumed
# to be the filepath for a test file to run.

if [[ -n $1 ]]; then
    echo 'running single file'
else
    echo 'running test suite'
    all_tests='true'
fi

if [[ -f "mvnw" ]]; then
    if [[ -n "$all_tests" ]]; then
        ./mvnw test
    else
        echo 'I would run a single mvn test if I knew how'
    fi
elif [[ -f "gradlew" ]]; then
    if [[ -n "$all_tests" ]]; then
        ./gradlew test --info # --stacktrace
    else
        ./gradlew test --tests="$1" --info # --stacktrace
    fi
else
    echo 'could not detect any tests to run'
fi
