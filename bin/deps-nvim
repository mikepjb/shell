#!/usr/bin/env bash

# Specific setup script for neovim and it's dependencies.

OS="$(uname)"
pkg_dir="$HOME/.config/nvim/pack/base/start"

if [[ "$OS" == "Linux" ]]; then
    sudo pacman -Syu neovim --needed
else
    brew upgrade neovim
fi

mkdir -p $pkg_dir

git clone https://github.com/nvim-telescope/telescope.nvim.git \
    $pkg_dir/telescope.nvim \
    --depth=1

git clone https://github.com/nvim-lua/plenary.nvim.git \
    $pkg_dir/plenary.nvim \
    --depth=1


git clone https://github.com/nvim-telescope/telescope-fzf-native.nvim.git \
    $pkg_dir/telescope-fzf-native.nvim \
    --depth=1

cd $pkg_dir/telescope-fzf-native.nvim && make && cd -
