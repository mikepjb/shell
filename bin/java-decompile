#!/usr/bin/env bash
#
# java-decompile: A bridge script to pass Vim's internal zipfile:// paths 
# cleanly into the CFR Java decompiler.

CFR_JAR="$HOME/.local/jars/cfr.jar"
INPUT_PATH="$1"

if [[ ! -f "$CFR_JAR" ]]; then
    echo "/* Error: CFR decompiler not found at $CFR_JAR */"
    exit 1
fi

if [[ "$INPUT_PATH" =~ ^zipfile:// ]]; then
    JAR_PATH=$(echo "$INPUT_PATH" | sed -E 's|^zipfile://(.*)::.*$|\1|')
    INTERNAL_PATH=$(echo "$INPUT_PATH" | sed -E 's|^.*::(.*)\.class$|\1|')
    CLASS_NAME=$(echo "$INTERNAL_PATH" | tr '/' '.')

    java -jar "$CFR_JAR" "$JAR_PATH" "$CLASS_NAME" --silent
else
    java -jar "$CFR_JAR" "$INPUT_PATH" --silent
fi

