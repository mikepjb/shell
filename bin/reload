#!/usr/bin/env bash

script_dir=$(dirname "$(realpath "$0")")
shell_repo_root=$(realpath "$script_dir/..")
sconf="$shell_repo_root/config"
local_bin_dir="$HOME/.local/bin"

echo 'Symlinking configurations'

# Extensionless config files go to $HOME/.$filename
for config_file in "$sconf/"*; do
    filename=$(basename "$config_file")
    if [ -d "$config_file" ] || [[ "$filename" == *.* ]]; then
        continue # skip config with file extensions, done manually below
    fi
    ln -sfv "$config_file" "$HOME/.$filename"
done

mkdir -p "$HOME"/.config/{clojure,nvim,ghostty,ctags}
mkdir -p "$HOME/.config/nvim/colors"
mkdir -p "$HOME/.vim/colors"
mkdir -p "$HOME/.config/ghostty/themes"

ln -sfv "$sconf/deps.edn" "$HOME/.config/clojure/deps.edn"
ln -sfv "$sconf/ghostty.conf" "$HOME/.config/ghostty/config"
ln -sfv "$sconf/spartan-dark.conf" "$HOME/.config/ghostty/themes/spartan-dark"
ln -sfv "$sconf/spartan-light.conf" "$HOME/.config/ghostty/themes/spartan-light"
ln -sfv "$sconf/vimrc" "$HOME/.vimrc"
ln -sfv "$sconf/ctags" "$HOME/.config/ctags/base.ctags"
ln -sfv "$sconf/spartan.vim" "$HOME/.vim/colors/spartan.vim"
ln -sfv "$sconf/init.lua" "$HOME/.config/nvim/init.lua"
ln -sfv "$sconf/spartan.lua" "$HOME/.config/nvim/colors/spartan.lua"

echo 'Symlinking scripts from ./bin'

for bin_file in "$shell_repo_root/bin/"*; do
    ln -sfv "$bin_file" "$local_bin_dir"
done

echo 'Reloading all configurations'

. ~/.bashrc
