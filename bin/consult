#!/usr/bin/env bash
#
# Consult is a script to be able to query Qwen or my local LLM of choice.
# Either within vim or via bash.
#
# Usage:
# - `cat src/core.clj | consult -p "review this file"`
# - `cat src/core.clj | consult` (Opens Vim to write instructions)

endpoint="http://127.0.0.1:7777/v1/chat/completions"
system_prompt="You are an expert senior software engineer. Your core expertise
is Clojure, but you are highly proficient in Rust, Go, JavaScript, TypeScript,
and Java.

Provide elite, production-grade code snippets, concise reviews, or direct
technical answers. Always default to Clojure unless another language is
explicitly specified.

CRITICAL DIRECTIVES:
1. Focus exclusively on idiomatic solutions, stable/standard libraries, and modern best practices.
2. Be direct, dense, and objective. Strip out conversational filler, introductions, greetings, and concluding remarks.
3. Deliver answers optimized for a terminal UI: prioritize clean code blocks over long prose explanations."

# pull in stdin if provided i.e `cat file.md | consult -p 'review this'`
context=""
if [ ! -t 0 ]; then
    context=$(cat -)
fi

# check if prompt was provided as a parameter, otherwise open vim to write it.
if [[ "$1" == "-p" ]]; then
    prompt="$2"
else
    tmp_file=$(mktemp /tmp/consult_prompt.XXXXXX)
    trap 'rm -f "$tmp_file"' EXIT
    vim "$tmp_file" < /dev/tty > /dev/tty
    prompt=$(grep -v '^#' "$tmp_file" | sed -e :a -e '/^\n*$/{$d;N;};/\n$/ba')

    if [ -z "$prompt" ]; then
        echo "⚠️ Prompt empty. Consult aborted."
        exit 0
    fi
fi

# include context if this was provided via stdin
if [ -n "$context" ]; then
    prompt="$prompt\n\n\n$context"
fi

payload=$(jq -n \
    --arg sys "$system_prompt" \
    --arg user "$prompt" \
    '{
        messages: [{role: "system", content: $sys}, {role: "user", content: $user}],
        stream: false,
        reasoning_format: "auto",
        chat_template_kwargs: {enable_thinking: false},
        reasoning_control: true,
        backend_sampling: false,
        timings_per_token: true
    }')

start_time=$(date +%s%N)
raw_response=$(curl -sS -X POST \
    -H "Content-Type: application/json" \
    -H "Transfer-Encoding:" \
    -d "$payload" "$endpoint")
end_time=$(date +%s%N)

response=$(echo "$raw_response" | jq -r '.choices[0].message.content // "Error: No content received."')
completion_tokens=$(echo "$raw_response" | jq -r '.usage.completion_tokens // 0')

duration_ns=$((end_time - start_time))
duration_sec=$(awk "BEGIN {print $duration_ns / 1000000000}")

tps='0.00'
if (( $(awk "BEGIN {print ($completion_tokens > 0 && $duration_sec > 0) ? 1 : 0}") )); then
    tps=$(awk "BEGIN {printf \"%.2f\", $completion_tokens / $duration_sec}")
fi

footer=$(printf "\n\n---\n*⏱️ Time taken: %.2fs | 🚀 Speed: %s tok/s (%s tokens)*" "$duration_sec" "$tokens_per_sec" "$completion_tokens")

if [ -t 1 ] && command -v glow &> /dev/null; then
    (echo "$response"; echo "$footer") | glow
else
    echo "$response"
    echo "$footer"
fi
