#!/usr/bin/env bash
#
# Consult is a script to be able to query Qwen or my local LLM of choice.
# Either within vim or via bash.
#
# Usage:
# - `cat src/core.clj | consult -m "review this file"`
# - `cat src/core.clj | consult` (Opens Vim to write instructions)

ENDPOINT="http://127.0.0.1:7777/v1/chat/completions"
MODEL="qwen-9b"
SYSTEM_PROMPT="You are an expert senior software engineer. Your core expertise
is Clojure, but you are highly proficient in Rust, Go, JavaScript, TypeScript,
and Java.

Provide elite, production-grade code snippets, concise reviews, or direct
technical answers. Always default to Clojure unless another language is
explicitly specified.

CRITICAL DIRECTIVES:
1. Focus exclusively on idiomatic solutions, stable/standard libraries, and modern best practices.
2. Be direct, dense, and objective. Strip out conversational filler, introductions, greetings, and concluding remarks.
3. Deliver answers optimized for a terminal UI: prioritize clean code blocks over long prose explanations."

# 1. Capture piped context if available
if [ ! -t 0 ]; then
    CONTEXT=$(cat -)
else
    CONTEXT=""
fi

# 2. Check for the Git-style -m flag
if [[ "$1" == "-m" || "$1" == "--message" ]]; then
    USER_INPUT="$2"
else
    # Fallback to Vim editor
    TMPFILE=$(mktemp /tmp/consult_prompt.XXXXXX)
    trap 'rm -f "$TMPFILE"' EXIT

    # Construct standard Git-style template
    echo -e "\n" > "$TMPFILE"
    echo "# ---------------------------------------------------------------------" >> "$TMPFILE"
    echo "# Please enter your prompt instructions above." >> "$TMPFILE"
    echo "# Lines starting with '#' will be ignored." >> "$TMPFILE"
    echo "# Leaving this file empty will abort the request." >> "$TMPFILE"
    echo "# ---------------------------------------------------------------------" >> "$TMPFILE"

    # Open Vim handling TTY redirection cleanly
    vim "$TMPFILE" < /dev/tty > /dev/tty

    # Strip out comments and cleanup whitespace
    USER_INPUT=$(grep -v '^#' "$TMPFILE" | sed -e :a -e '/^\n*$/{$d;N;};/\n$/ba')

    if [ -z "$USER_INPUT" ]; then
        echo "⚠️ Prompt empty. Consult aborted."
        exit 0
    fi
fi

# 3. Combine Context and Instructions
if [ -n "$CONTEXT" ]; then
    FULL_PROMPT=$(printf "\`\`\`\n%s\n\`\`\`\n\n%s" "$CONTEXT" "$USER_INPUT")
else
    FULL_PROMPT="$USER_INPUT"
fi

# 4. Build Payload and Execute
PAYLOAD=$(jq -n \
    --arg model "$MODEL" \
    --arg sys "$SYSTEM_PROMPT" \
    --arg user "$FULL_PROMPT" \
    '{model: $model, messages: [{role: "system", content: $sys}, {role: "user", content: $user}]}')

START_TIME=$(date +%s%N)
RAW_RESPONSE=$(curl -sS -X POST -H "Content-Type: application/json" -d "$PAYLOAD" "$ENDPOINT")
END_TIME=$(date +%s%N)

RESPONSE=$(echo "$RAW_RESPONSE" | jq -r '.choices[0].message.content // "Error: No content received."')
COMPLETION_TOKENS=$(echo "$RAW_RESPONSE" | jq -r '.usage.completion_tokens // 0')

DURATION_NS=$((END_TIME - START_TIME))
DURATION_SEC=$(awk "BEGIN {print $DURATION_NS / 1000000000}")

if (( $(awk "BEGIN {print ($COMPLETION_TOKENS > 0 && $DURATION_SEC > 0) ? 1 : 0}") )); then
    TOKENS_PER_SEC=$(awk "BEGIN {printf \"%.2f\", $COMPLETION_TOKENS / $DURATION_SEC}")
else
    TOKENS_PER_SEC="0.00"
fi

STATS_FOOTER=$(printf "\n\n---\n*⏱️ Time taken: %.2fs | 🚀 Speed: %s tok/s (%s tokens)*" "$DURATION_SEC" "$TOKENS_PER_SEC" "$COMPLETION_TOKENS")

if [ -t 1 ] && command -v glow &> /dev/null; then
    (echo "$RESPONSE"; echo "$STATS_FOOTER") | glow
else
    echo "$RESPONSE"
    echo "$STATS_FOOTER"
fi
