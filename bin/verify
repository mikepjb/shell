#!/usr/bin/env bash
# Test runner, identifies the right call
# Supports single file (1 arg) and whole suite (0 arg) runs)

filename=$(basename "$1")
extension="${filename##*.}"

# If extension is missing or same as filename, try to detect via shebang
if [[ "$filename" == "$extension" ]] || [[ -z "$extension" ]]; then
    if [[ -f "$1" ]]; then
        line=$(head -n 1 "$1")
        if [[ "$line" =~ ^#! ]]; then
            # 1. Remove the #! prefix
            clean_line="${line##!}"
            # 2. Get the last word (this handles both /bin/bash and /env bash)
            lang=$(echo "$clean_line" | awk '{print $NF}')
            # 3. Final cleanup: strip path if the last word is a path like /bin/sh
            lang="${lang##*/}"
        else
            lang="sh"
        fi
    else
        lang="sh"
    fi
else
    lang="$extension"
fi

filepath=$1

# Normalize bash/zsh to sh to match your existing test blocks
[[ "$lang" == "bash" || "$lang" == "zsh" ]] && lang="sh"

echo "--- Running $lang tests ---"

if [[ "$lang" == "sh" ]]; then
    if [[ -f "$filepath" ]]; then
        shellcheck "$filepath"
    else
        echo "No specific shell file provided to shellcheck."
    fi
fi

if [[ "$lang" =~ ^(js|ts)$ ]]; then
    if [[ -f "$filepath" ]]; then
        node --test "$filepath"
    else
        cat package.json | jq -r '.scripts.test' | bash
    fi
fi

if [[ "$lang" == "go" ]]; then
    if [[ -f "$filepath" ]]; then
        go test "$filepath"
    else
        go test ./...
    fi
fi
