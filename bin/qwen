#!/usr/bin/env bash
#
# N.B 2B hallucenates too much (i.e thinks lucene-clojure exists)
# 4B seems to be a good balance of speed and quality
# ..having said that, perhaps this is what we want - the subset of more helpful
# info is going to be around using a core/stable stdlib vs. figuring out
# individual libraries.

model_file="$HOME/models/Qwen3.5-4B-UD-Q3_K_XL.gguf" 

if [ ! -f $model_file ]; then
    hf download \
        unsloth/Qwen3.5-4B-GGUF \
        Qwen3.5-4B-UD-Q3_K_XL.gguf \
        --local-dir ~/models
fi

llama-server \
    -m "$model_file" \
    --jinja \
    --host 127.0.0.1 \
    --port 7777 \
    -c 16384 \
    --metrics \
    -ngl -1 \
    -np 1 \
    --temp 0.6 \
    --top-p 0.95 \
    --top-k 20 \
    --min-p 0.00 \
    --presence-penalty 0.0 \
    --repeat-penalty 1.05
