#!/usr/bin/env bash
#
# N.B 2B hallucenates too much (i.e thinks lucene-clojure exists)
# 4B seems to be a good balance of speed and quality
# ..having said that, perhaps this is what we want - the subset of more helpful
# info is going to be around using a core/stable stdlib vs. figuring out
# individual libraries.
# Now experimenting with 9B at Q5 quantisation from 70tps down to 40tps vs. 4B
# Q3.

model_file="$HOME/models/Qwen3.5-9B-UD-Q5_K_XL.gguf" 

if [ ! -f $model_file ]; then
    hf download \
        unsloth/Qwen3.5-9B-GGUF \
        Qwen3.5-9B-UD-Q5_K_XL.gguf \
        --local-dir ~/models
fi

args=(
    -m "$model_file"        # Path to the model file
    --no-jinja              # We don't use tool calls so jinja is not necessary
    --host 127.0.0.1
    --port 7777
    -c 16384                # Context size (tokens)
    --cache-prompt          # Cache the prompt to speed up requests
    --metrics               # Show tps etc in llama-server's logs
    -ngl -1                 # Offload all layers to GPU (-1)
    -np 1                   # Number of parallel slots/users
    --flash-attn on         # Enable Flash Attention for speed
    --temp 0.6              # LLM temperature (creativity)
    --top-p 0.95            # Top-p sampling
    --top-k 20              # Top-k sampling
    --min-p 0.00            # Minimum probability threshold
    --reasoning off         # Disable internal reasoning tokens if applicable
    # --presence-penalty 0.0  # Penalty for repeating topics
    # --repeat-penalty 1.05   # Penalty for repeating exact words
)

llama-server "${args[@]}"
