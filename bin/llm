#!/usr/bin/env bash
#
# Currently trialing Qwen 3.5 4B (Q5)
#
# Previous models:
# - Qwen 3.5 2B (Q3) :: hallucenates too much (i.e thinks lucene-clojure exists)
# - Qwen 3.5 4B (Q3) :: good balance speed/quality, limited to stdlib/core knowledge
# - Qwen 3.5 9B (Q5) :: 40tps, good results but will sometimes hang
# - Gemma 4 12B (Q5) :: Good on M3 Max (~30tps) does not load on my 780M
# - Theorised Qwen 3.5 2B with finetuning (Clojure open source?), for my
# particular use case this could be gold!

model_size="4B"
model_file="$HOME/models/Qwen3.5-$model_size-UD-Q5_K_XL.gguf"

if [ ! -f $model_file ]; then
    hf download \
        "unsloth/Qwen3.5-$model_size-GGUF" \
        "Qwen3.5-$model_size-UD-Q5_K_XL.gguf" \
        --local-dir ~/models
fi

args=(
    -m "$model_file"       # Path to the model file
    --jinja                # Required for Gemma 4 12B, otherwise prefer --no-jinja
    --host 127.0.0.1
    --port 7777
    -c 8096                # Context size (tokens)
    --cache-prompt         # Cache the prompt to speed up requests
    --metrics              # Show tps etc in llama-server's logs
    -ngl -1                # Offload all layers to GPU (-1)
    -np 1                  # Number of parallel slots/users
    --temp 1               # LLM temperature (creativity) (1 for Gemma, 0.6 Qwen)
    --top-p 0.95           # Top-p sampling
    --top-k 20             # Top-k sampling (64 for Gemma, 20 for Qwen)
    --flash-attn on        # Enable Flash Attention for speed
    --repeat-penalty 1.0   # 1.0 == disabled
    --presence-penalty 0.0 # 0.0 == disabled
)

llama-server "${args[@]}"
