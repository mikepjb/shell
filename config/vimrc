" TODO to help with source navigation, can we use ctags to list all functions
" in the buffer? or does vim support this natively like emacs does with imenu?

" TODO problem for java in first time loading, will do the right thing but
" error (extracts + runs ctags but doesn't put user in file)
" we should also echo before delegating so the user knows the request was
" actually fired lol
function! LookupSource(level, ...) abort
    " Determine the language/filetype
    if a:0 > 0 && !empty(a:1)
        let l:lang = a:1
    else
        let l:lang = &filetype
    endif

    if empty(l:lang)
        echoerr "No language specified and no filetype detected."
        return
    endif

    let l:script_path = expand('~/.local/bin/lookup-deps')
    let l:result_path = ''

    " LEVEL: LANG (Core JDK)
    if a:level ==# 'lang'
        let l:cmd = printf('%s --level lang --lang %s', shellescape(l:script_path), shellescape(l:lang))
        let l:result_path = trim(system(l:cmd))

    " mvn dependency:sources
    " LEVEL: DEP (Maven + Gradle Ecosystem)
    elseif a:level ==# 'dep'
        if l:lang ==# 'java'
            let l:m2 = expand('~/.m2/repository')
            let l:gradle = expand('~/.gradle/caches/modules-2/files-2.1')

            " mvn dependency:sources
            " clojure -Spom && mvn dependency:sources && rm pom.xml
            " Structure the fd command: fd -g <pattern> <path1> <path2>
            let l:find_cmd = printf('fd -g "*-sources.jar" %s %s', shellescape(l:m2), shellescape(l:gradle))
            let l:selected_jar = trim(system(l:find_cmd . ' | selecta'))
            redraw!

            " Handle user hitting Esc / cancelling selecta
            if empty(l:selected_jar) || v:shell_error != 0
                echo "Selection cancelled."
                return
            endif

            " Pass the cleanly selected jar file down to the bash worker
            let l:cmd = printf('%s --extract-jar %s', shellescape(l:script_path), shellescape(l:selected_jar))
            let l:result_path = trim(system(l:cmd))
        else
            echoerr "Dependency lookup for " . l:lang . " is not implemented yet."
            return
        endif
    endif

    " Open the final workspace tab if everything succeeded
    if v:shell_error == 0 && isdirectory(l:result_path)
        execute 'tabnew'
        execute 'lcd ' . fnameescape(l:result_path)
        execute 'edit .'
        echo "Opened local documentation for: " . l:lang
    else
        echoerr "Lookup failed: " . l:result_path
    endif
endfunction

" Bind commands to match your workflow
command! -nargs=? LookupLang call LookupSource('lang', <f-args>)
command! -nargs=? LookupDep  call LookupSource('dep', <f-args>)
