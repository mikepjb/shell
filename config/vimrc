function! TabContent()
  let s = ''
  for i in range(tabpagenr('$'))
    let tabnr = i + 1 " range() starts at 0
    let s .= '%' . tabnr . 'T' " Setup click target and highlighting
    let s .= (tabnr == tabpagenr() ? '%#TabLineSel#' : '%#TabLine#')
    let tab_pwd = gettabvar(tabnr, 'tab_pwd', getcwd())
    let folder_name = fnamemodify(tab_pwd, ':t')
    let s .= empty(folder_name) ? ' [/] ' : ' ' . folder_name . ' '
  endfor
  
  return s .. '%#TabLineFill#'
endfunction

