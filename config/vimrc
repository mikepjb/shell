autocmd!

set nocompatible
syntax on
filetype plugin indent on

set clipboard=unnamed,unnamedplus
set mouse=a
set number " maybe disable and only enable for prog modes?
set hidden
set history=10000
set expandtab
set tabstop=2 shiftwidth=2 softtabstop=2
set showmatch
set incsearch
set hlsearch
set ignorecase smartcase
set cursorline
set cmdheight=1
set switchbuf=useopen
set showtabline=2 " always show the tab bar
set laststatus=2 " always show the status line
set winwidth=79
set scrolloff=3
set nobackup nowritebackup
set backupdir=~/.vim-tmp,~/.tmp,~/tmp,/var/tmp,/tmp
set directory=~/.vim-tmp,~/.tmp,~/tmp,/var/tmp,/tmp
set backspace=indent,eol,start
set showcmd
set shell=bash
set wildmode=longest,list
set wildmenu
set wildignore=*.class,*.jpg,*.png,*.gif,*.pdf
set timeout timeoutlen=1000 ttimeoutlen=100
set foldmethod=manual
set nofoldenable " disable folding.. we may want this for markdown notes later
set nojoinspaces " joining lines is smart about whitespace
set autoread
" set re=1 " ruby is faster on old regex engine, keep this for reference
set diffopt=vertical " show diffs side by side not vertically
set signcolumn=no
" set termguicolors " probably don't want this tbh.
set updatetime=200
set completeopt=menu,preview
set statusline=%<%f\ (%{&ft})\ %-4(%m%)%=%-19(%3l,%02c%03V%)

set splitbelow splitright " set default new split behaviour
set visualbell
set autowrite " auto-save on :make and other commands

