" -----------------------------------------
" Spartan config
" -----------------------------------------
"  TODO also snippets for html/css at least
"  TODO lang/dep lookup (and java dep class decompile)

set nocompatible " Disable VI Compatibility
syntax on
filetype plugin indent on

set autoindent
set backspace=indent,eol,start
set formatoptions-=t              " Don't add line-breaks for lines over 'textwidth' chars
set hlsearch
set incsearch                     " cursor follows matches as you /search
set smartcase                     " ignore case unless I search specifically for uppercase
set ignorecase
set nonumber
set nostartofline
set showmatch
set showcmd                       " bottom right of screen shows partially-typed commands i.e 'g'
set textwidth=80                  " 80 columns
set fillchars=vert:│
set belloff=all
set clipboard=unnamed,unnamedplus
set nobackup
set nowritebackup
set noswapfile
set tabstop=4                     " Number of spaces <tab> counts for
set softtabstop=4
set shiftwidth=4
set expandtab                     " Space > Tabs
set colorcolumn=+1
set nowrap
set path+=** " expands find results in a fuzzy manner
set gdefault                      " replaces all matches, not just the first
set re=2                          " re=1 by default, typescript hl is slow without this
set statusline=%<%f%*\ (%{&ft})\ %-4(%m%)%=%-19(%3l,%02c%03V%)
set laststatus=2
set notermguicolors

if !isdirectory("/tmp/.vim-undo-dir")
    call mkdir("/tmp/.vim-undo-dir", "", 0700)
endif
set undodir=/tmp/.vim-undo-dir
set undofile

" prevent remaps
let g:omni_sql_no_default_maps = 1
let g:sh_noisk=1

if executable('rg') " N.B ripgrep searches all files by default
  set grepprg=rg\ --vimgrep\ --smart-case\ $*
  set grepformat=%f:%l:%c:%m,%f:%l:%m
endif

colorscheme spartan

nnoremap Y y$
nnoremap <c-j> <c-w>j
nnoremap <c-k> <c-w>k
nnoremap <c-h> <c-w>h
nnoremap <c-l> <c-w>l
inoremap <c-l> <space>=><space>
inoremap <c-c> <esc>
nnoremap S <c-^>
nnoremap <c-q> :q<CR>
nnoremap <c-g> :noh<CR><c-g>
nnoremap gd <C-]> " check if this conflicts with vim-fireplace
nnoremap gD g<C-]>
nnoremap gi :e ~/.vimrc<CR>
nnoremap gn :lcd ~/.notes <bar> e ~/.notes/index.md<CR>
nnoremap ge :e <C-R>=fnamemodify(resolve(expand('%:p')), ':h') . '/'<CR>
nnoremap gs :grep<space>
nnoremap gc :!ctags -R .<CR>
nnoremap gl :cclose<CR>
nnoremap Q @q
xmap ga <Plug>(EasyAlign)
nmap ga <Plug>(EasyAlign)
nnoremap <A-n> :cnext<CR>
nnoremap <A-p> :cprevious<CR>
cnoremap        <C-A> <Home>
cnoremap        <C-B> <Left>
cnoremap <expr> <C-D> getcmdpos()>strlen(getcmdline())?"\<Lt>C-D>":"\<Lt>Del>"
cnoremap <expr> <C-F> getcmdpos()>strlen(getcmdline())?&cedit:"\<Lt>Right>"
nnoremap Z :echo map(synstack(line('.'), col('.')), 'synIDattr(v:val, "name")')<CR>

augroup base
    autocmd!
    autocmd BufEnter * :syntax sync fromstart
    autocmd BufReadPost quickfix nnoremap <buffer> <CR> <CR>
    " TODO what do these quickfix autocmds do?
    " autocmd QuickFixCmdPost cgetexpr cwindow
    " autocmd QuickFixCmdPost lgetexpr lwindow
	autocmd QuickFixCmdPost [^l]* nested cwindow
    autocmd CmdwinEnter * nnoremap <buffer> <CR> <CR>
    autocmd FileType markdown setlocal nonumber
    autocmd FileType clojure packadd vim-fireplace
    autocmd FileType ruby,html,clojure setl ts=2 sw=2 sts=2
augroup END

command! SudoWrite :w !sudo tee > /dev/null %
command! TrimWhitespace :%s/\s\+$//
command! GenerateHelpTags :helptags ALL
command! -range -nargs=* Align <line1>,<line2>!column <args>

function! SelectaCommand(choice_command, selecta_args, vim_command)
  try
    exec a:vim_command . " " . SelectaOutput(a:choice_command, a:selecta_args)
  catch /Vim:Interrupt/
    redraw!
    return
  endtry
endfunction

function! SelectaOutput(choice_command, selecta_args)
  let selection = system(a:choice_command . " | selecta " . a:selecta_args)
  let selection = substitute(selection, ' ', '\\ ', "g")
  redraw!
  return selection
endfunction

function! SelectaFile(path, glob, command)
  call SelectaCommand("fd -t f . " . a:path, "", a:command)
endfunction

nnoremap <space> :call SelectaFile(".", "*", ":edit")<cr>

function Test()
    if filereadable("mvnw")
        set makeprg=./mvnw\ test
        " Standard Maven error format
        set errorformat=[ERROR]\ %f:[%l\\,%c]\ %m,%-G%.%#
    elseif filereadable("gradlew")
        set makeprg=./gradlew\ test
        set errorformat=
                    \%f:%l:\ error:\ %m,
                    \%-G%.%#
    else
        echom "No test configuration detected"
        return
    endif

    make
endfunction

command! Test :call Test()<CR>
