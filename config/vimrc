" -----------------------------------------
" Vim configuration
" -----------------------------------------

set nocompatible " Disable VI Compatibility
syntax on
filetype plugin indent on

set autoindent
set backspace=indent,eol,start
set formatoptions-=t              " Don't add line-breaks for lines over 'textwidth' chars
set hlsearch incsearch ignorecase " highlight matches live + ignore case matching
set nonumber
set nostartofline
set showmatch
set textwidth=80 colorcolumn=+1   " 80 column width + highlight
set fillchars=vert:│
set belloff=all
set clipboard=unnamed,unnamedplus
set nowrap
set gdefault                      " replaces all matches, not just the first
set re=2                          " re=1 by default, typescript hl is slow without this
set nowritebackup noswapfile      " no temporary files please, git covers saves
set laststatus=2
set tabstop=2 softtabstop=2 shiftwidth=2 expandtab " 2-width, prefer spaces > tab
set statusline=%<%f%*\ (%{&ft})\ %-4(%m%)%=%-19(%3l,%02c%03V%)
let &l:errorformat = '%f:%l:%c:\ %m,%f:%l:\ %m,%-G%.%#'
let [g:omni_sql_no_default_maps, g:sh_noisk] = [1, 1] " prevent remaps
let g:markdown_fenced_languages=['bash=sh', 'css', 'html', 'go', 'ruby', 'sql', 'yaml']

set undodir=/tmp/.vim-undo-dir undofile
if !isdirectory(&undodir)
  call mkdir(&undodir, "", 0700)
endif

if executable('rg') " N.B ripgrep searches all files by default
  set grepprg=rg\ --vimgrep\ --smart-case\ $*
  set grepformat=%f:%l:%c:%m,%f:%l:%m
endif

colorscheme spartan

nnoremap Y y$
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-h> <C-w>h
nnoremap <C-l> <C-w>l
inoremap <C-l> <space>=><space>
inoremap <C-c> <esc>
nnoremap S <C-^>
nnoremap <C-q> :q<CR>
nnoremap <C-g> :noh<CR>:redraw!<CR><C-g>
nnoremap gd <C-]>
nnoremap gi :e ~/.vimrc<CR>
nnoremap gn :e ~/.notes/index.md<CR>
nnoremap ge :e <C-R>=fnamemodify(resolve(expand('%:p')), ':h') . '/'<CR>
nnoremap gs :grep<space>
nnoremap gc :!ctags -R .<CR>
nnoremap gr :read !snip<space>
nnoremap <expr> gl empty(filter(getwininfo(), 'v:val.quickfix')) ? ':copen<CR>' : ':cclose<CR>'
nnoremap Q @q
nnoremap <A-n> :cnext<CR>
nnoremap <A-p> :cprevious<CR>
cnoremap        <C-A> <Home>
cnoremap        <C-B> <Left>
cnoremap <expr> <C-D> getcmdpos()>strlen(getcmdline())?"\<Lt>C-D>":"\<Lt>Del>"
cnoremap <expr> <C-F> getcmdpos()>strlen(getcmdline())?&cedit:"\<Lt>Right>"
nnoremap Z :echo map(synstack(line('.'), col('.')), 'synIDattr(v:val, "name")')<CR>
nnoremap <A-t> :cexpr system('test-this ' . expand('%'))<cr>
nnoremap <A-T> :cexpr system('test-this')<cr>
nnoremap <A-r> :cexpr system('lint-this "' . expand('%') . '"')<cr>
nnoremap <A-R> :cexpr system('lint-this "' . expand('%') . '" --fix')<cr>

augroup base
  autocmd!
  autocmd BufEnter * :syntax sync fromstart
  autocmd QuickFixCmdPost [^l]* nested cwindow
  autocmd FileType markdown setlocal formatoptions+=t " wrap lines in .md
  autocmd FileType clojure packadd vim-fireplace
  autocmd FileType go,java,rust,sh setl ts=4 sw=4 sts=4
augroup END

function! SelectaCommand(choice_command, selecta_args, vim_command)
  try
    let selection = system(a:choice_command . " | selecta " . a:selecta_args)
    let selection = substitute(selection, ' ', '\\ ', "g")
    redraw!
    exec a:vim_command . " " . selection
  catch /Vim:Interrupt/
    redraw!
  endtry
endfunction

nnoremap <space> :call SelectaCommand("fd -t f . .", "", ":edit")<cr>
nnoremap <A-o> :call SelectaCommand("fd -t f . ~/.notes/", "", ":edit")<cr>
